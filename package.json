{
  "name": "event-order",
  "version": "1.0.0",
  "description": "Software di cassa locale non fiscale, configurabile per qualsiasi attivita' o evento.",
  "main": "src/server.js",
  "scripts": {
    "lint": "eslint .",
    "test": "npm run lint && node --test test/*.test.js",
    "test:e2e": "playwright test",
    "test:scale": "node --test --test-name-pattern='100\\.000|lettore esterno' test/*.test.js",
    "test:fault": "node --test --test-name-pattern='interrott|incompatibile|backup preventivo|stampa pendente|risposta persa' test/*.test.js",
    "coverage": "node --test --experimental-test-coverage --test-coverage-include='src/**/*.js' --test-coverage-lines=90 --test-coverage-branches=70 --test-coverage-functions=90 test/*.test.js",
    "dev": "nodemon src/server.js",
    "start": "node src/server.js"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "keywords": [
    "pos",
    "cassa",
    "registratore-di-cassa",
    "eventi",
    "sagre",
    "non-fiscale"
  ],
  "author": "Emidio Schirano <emidioschirano@gmail.com>",
  "license": "MIT",
  "dependencies": {
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/onest": "^5.3.0",
    "better-sqlite3": "^12.11.1",
    "chart.js": "^4.5.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "sortablejs": "^1.15.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "nodemon": "^3.1.14"
  },
  "allowScripts": {
    "better-sqlite3@12.11.1": true,
    "fsevents@2.3.3": true
  }
}
