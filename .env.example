# Porta del server
PORT=3000
# Interfaccia di ascolto. Default sicuro: solo questa macchina.
# Per accedere da un tablet in LAN usa 0.0.0.0 e configura anche APP_PIN.
HOST=127.0.0.1

# --- Branding / generalizzazione ---
# Nome mostrato nell'interfaccia (header, titoli pagina)
APP_NAME=EventOrder
# Nome dell'attivita' stampato sul ticket (default: uguale ad APP_NAME)
BUSINESS_NAME=
# Sottotitolo opzionale
APP_TAGLINE=Cassa locale

# --- Valuta e localizzazione ---
CURRENCY_SYMBOL=€
LOCALE=it-IT

# --- Operatori e accesso ---
# Elenco operatori selezionabili all'apertura del turno (vuoto = nessuna scelta)
# OPERATORS=Anna,Luca,Marco
# PIN numerico di 1-8 cifre per proteggere l'accesso (vuoto = nessuna protezione)
# APP_PIN=1234

# --- Comportamento ---
# Inserisce prodotti demo al primo avvio con DB vuoto (0 per disattivare)
POS_SEED_DEMO=1
# Numero di backup da conservare (0 = illimitato)
BACKUP_KEEP=20
# Percorso del file database (default: pos.sqlite nella cartella del progetto)
# POS_DB_PATH=/percorso/assoluto/pos.sqlite
